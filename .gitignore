# Claude Code内部ファイル（不要）
.claude/debug/
.claude/backups/
.claude/shell-snapshots/
.claude/todos/
.claude/statsig/
.claude/telemetry/
.claude/.credentials.json
.claude/mcp-needs-auth-cache.json
.claude/settings.local.json
.claude/plugins/
.claude/projects/
nul

# ワークツリー
.claude/worktrees/
.worktrees/

# MCP設定（APIキー含む）
.mcp.json

# 自動生成ファイル
.claude.json
.claude.json.backup
.cache/
*.db-shm
*.db-wal

# Playwright browser profile
.playwright-data/
.playwright-mcp/

# ツール内部ディレクトリ
.firecrawl/
.superpowers/

# バイナリ実行ファイル
claude-office/cloudflared.exe

# Drive同期PDF（リポジトリ管理不要）
knowledge/students/drive-pdfs/

# おさる教材PDF（大容量）
osaru-pdf*.pdf

# 一時ファイル
.tmp-*
.tmp.driveupload/

# その他
node_modules/
*.log
.env

# claude-office runtime data (keep .gitkeep only)
claude-office/data/*.json
claude-office/data/messages/*.json
claude-office/data/drafts/*.json
claude-office/data/results/*.json

# claude-office runtime text data
claude-office/data/*.txt
claude-office/data/*.md

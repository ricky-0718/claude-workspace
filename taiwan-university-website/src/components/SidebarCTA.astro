---
interface Props {
  pageType?: string;
  schoolSlug?: string;
}

const { pageType = 'top', schoolSlug } = Astro.props;

const baseLineUrl = 'https://lin.ee/placeholder';
const params = new URLSearchParams({ src: 'db', page: pageType });
if (schoolSlug) params.set('school', schoolSlug);
const lineUrl = `${baseLineUrl}?${params.toString()}`;
---

<aside class="hidden sm:block sticky top-20 p-5 bg-warm-50 border border-warm-200 rounded-2xl" aria-label="無料ガイドブック">
  <div class="text-center">
    <svg class="w-10 h-10 text-primary mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>
    <p class="font-bold text-sm text-text mb-1">無料ガイドブック</p>
    <p class="text-xs text-text-secondary mb-4 leading-relaxed">
      出願から卒業まで<br />がわかる1冊
    </p>
    <a
      href={lineUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="flex items-center justify-center gap-1.5 w-full bg-line hover:bg-line-dark text-white font-bold py-2.5 rounded-xl text-xs transition-colors duration-150 shadow-md shadow-line/15"
      aria-label="LINE登録でガイドブックを受け取る"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
      LINE登録で受け取る
    </a>
    <div class="mt-3 space-y-1 text-[11px] text-text-muted text-left">
      <p class="flex items-center gap-1">
        <svg class="w-3 h-3 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        合格率100%
      </p>
      <p class="flex items-center gap-1">
        <svg class="w-3 h-3 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        3ヶ月でTOCFL A2
      </p>
    </div>
  </div>
</aside>

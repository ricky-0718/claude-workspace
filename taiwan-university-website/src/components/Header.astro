---
const navItems = [
  { label: '学群から探す', href: '/groups/' },
  { label: '大学一覧', href: '/universities/' },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-primary font-bold text-lg shrink-0">
      <svg class="w-7 h-7" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="28" height="28" rx="6" fill="currentColor"/>
        <text x="14" y="20" text-anchor="middle" fill="white" font-size="16" font-weight="bold">台</text>
      </svg>
      <span class="hidden sm:inline">台湾大学DB</span>
    </a>

    <nav class="flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm text-gray-600 hover:text-primary hover:bg-primary-light rounded-lg transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

---
const navItems = [
  { label: '大学一覧', href: '/universities/' },
  { label: '学群から探す', href: '/groups/' },
  { label: 'ランキング', href: '/rankings/' },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-warm-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group">
      <div class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center">
        <span class="text-white font-bold text-base leading-none">台</span>
      </div>
      <div class="hidden sm:flex flex-col">
        <span class="font-display font-bold text-primary text-sm leading-tight tracking-wide">TAIWAN UNIV DB</span>
        <span class="text-[10px] text-text-muted leading-tight">台湾留学101センター</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden sm:flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary hover:bg-primary-50 rounded-lg transition-colors duration-150"
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://sub.ryugaku101.com/line/open/25Cs24s6JgYa"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-2 px-4 py-2 text-sm font-bold text-white bg-line hover:bg-line-dark rounded-lg transition-colors duration-150"
      >
        LINE相談
      </a>
    </nav>

    <!-- Mobile Nav -->
    <nav class="flex sm:hidden items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class="px-2.5 py-1.5 text-xs font-medium text-text-secondary hover:text-primary rounded-md transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

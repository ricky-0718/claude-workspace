---
interface Props {
  variant: 'national' | 'private' | 'chinese' | 'english' | 'interview';
  label: string;
}

const { variant, label } = Astro.props;

const styles: Record<string, string> = {
  national: 'bg-national-bg text-national',
  private: 'bg-private-bg text-private',
  chinese: 'bg-chinese-tag-bg text-chinese-tag',
  english: 'bg-english-tag-bg text-english-tag',
  interview: 'bg-warning-light text-warning',
};
---

<span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${styles[variant]}`}>
  {label}
</span>

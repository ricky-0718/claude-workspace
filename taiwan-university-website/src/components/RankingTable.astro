---
import type { SchoolSlugResolver } from '../utils/rankingHelpers';

interface RankingRow {
  name_cht: string;
  name_en?: string;
  rankValue: any;
  secondaryValue?: any;
}

interface Props {
  title: string;
  description: string;
  primaryLabel: string;
  secondaryLabel?: string;
  rows: RankingRow[];
  getSlug: SchoolSlugResolver;
}

const { title, description, primaryLabel, secondaryLabel, rows, getSlug } = Astro.props;

function formatRank(rank: any): string {
  if (rank == null) return '—';
  return String(rank);
}
---

<div class="bg-white border border-warm-200 rounded-2xl overflow-hidden">
  <div class="px-5 py-3 bg-warm-50 border-b border-warm-200">
    <h2 class="text-sm font-bold text-text">{title}</h2>
    <p class="text-xs text-text-muted mt-0.5">{description}（{rows.length}校掲載）</p>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-warm-200 text-left">
          <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider w-20">{primaryLabel}</th>
          <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider">大学名</th>
          {secondaryLabel && (
            <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider text-right w-20">{secondaryLabel}</th>
          )}
        </tr>
      </thead>
      <tbody>
        {rows.map((r, i) => {
          const slug = getSlug(r.name_cht);
          return (
            <tr class={`border-b border-warm-100 last:border-b-0 ${i < 3 ? 'bg-accent-light/30' : ''}`}>
              <td class="px-5 py-3 font-bold text-primary">{formatRank(r.rankValue)}</td>
              <td class="px-5 py-3">
                {slug ? (
                  <a href={`/universities/${slug}/`} class="text-text hover:text-primary transition-colors font-medium">
                    {r.name_cht}
                  </a>
                ) : (
                  <span class="text-text">{r.name_cht}</span>
                )}
                {r.name_en && <div class="text-xs text-text-muted mt-0.5">{r.name_en}</div>}
              </td>
              {secondaryLabel && (
                <td class="px-5 py-3 text-right text-text-muted font-medium">{formatRank(r.secondaryValue)}</td>
              )}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>

---
import Badge from './Badge.astro';
import RankingBadge from './RankingBadge.astro';
import type { School } from '../data/loaders';
import { getSchoolTypeLabel, isNational } from '../data/loaders';

interface Props {
  school: School;
}

const { school } = Astro.props;
const typeLabel = getSchoolTypeLabel(school.type);
const national = isNational(school.type);
---

<a
  href={`/universities/${school.resolvedSlug}/`}
  class="group block bg-white border border-warm-200 rounded-2xl overflow-hidden hover:border-primary hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
  data-region={school.region}
  data-type={typeLabel}
  data-dorm={school.dormitory?.available ? 'true' : 'false'}
  data-scholarship={school.scholarship?.available ? 'true' : 'false'}
>
  {/* Image header */}
  <div class="h-28 bg-gradient-to-br from-primary/5 to-primary/15 relative">
    {school.image?.url ? (
      <img src={school.image.url} alt={school.name.ja} class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="text-3xl font-black text-primary/15">{school.name.ja.charAt(0)}</span>
      </div>
    )}
    {/* Ranking badge overlay */}
    {school.rankings && (
      <div class="absolute top-2 right-2">
        <RankingBadge rankings={school.rankings} compact />
      </div>
    )}
  </div>

  <div class="p-4">
    <h3 class="font-bold text-sm text-text group-hover:text-primary transition-colors truncate">
      {school.name.ja}
    </h3>
    <p class="text-xs text-text-muted mt-0.5 truncate">{school.name.en}</p>

    <div class="flex flex-wrap gap-1.5 mt-2.5">
      <Badge variant={national ? 'national' : 'private'} label={typeLabel} />
      <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-warm-100 text-text-secondary">
        {school.region}
      </span>
      {school.dormitory?.available && (
        <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-success-light text-success">寮あり</span>
      )}
      {school.scholarship?.available && (
        <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-accent-light text-warning">奨学金</span>
      )}
    </div>

    <div class="flex items-center justify-between mt-3 pt-3 border-t border-warm-100 text-xs text-text-muted">
      <span>{school.department_count || '—'}学科</span>
      {school.student_count?.japanese != null && school.student_count.japanese > 0 && (
        <span class="text-primary font-medium">日本人 {school.student_count.japanese}名</span>
      )}
    </div>
  </div>
</a>

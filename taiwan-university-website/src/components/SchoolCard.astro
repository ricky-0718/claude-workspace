---
import Badge from './Badge.astro';
import type { School } from '../data/loaders';
import { getSchoolTypeLabel, isNational } from '../data/loaders';

interface Props {
  school: School;
}

const { school } = Astro.props;
const typeLabel = getSchoolTypeLabel(school.type);
const national = isNational(school.type);
---

<a
  href={`/universities/${school.resolvedSlug}/`}
  class="group block bg-white border border-gray-200 rounded-xl p-4 hover:border-primary hover:shadow-md transition-all"
  data-region={school.region}
  data-type={typeLabel}
  data-dorm={school.dormitory?.available ? 'true' : 'false'}
  data-scholarship={school.scholarship?.available ? 'true' : 'false'}
>
  <div class="flex items-start gap-3">
    <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center text-primary font-bold text-sm shrink-0">
      {school.name.ja.charAt(0)}
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="font-bold text-sm text-gray-800 group-hover:text-primary transition-colors truncate">
        {school.name.ja}
      </h3>
      <p class="text-xs text-gray-400 mt-0.5 truncate">{school.name.en}</p>
    </div>
  </div>

  <div class="flex flex-wrap gap-1.5 mt-3">
    <Badge variant={national ? 'national' : 'private'} label={typeLabel} />
    <span class="inline-block px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-600">
      {school.region}
    </span>
    {school.dormitory?.available && (
      <span class="inline-block px-2 py-0.5 rounded text-xs bg-green-light text-green">寮あり</span>
    )}
    {school.scholarship?.available && (
      <span class="inline-block px-2 py-0.5 rounded text-xs bg-gold-light text-gold">奨学金</span>
    )}
  </div>

  {school.ja_description && (
    <p class="text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed">
      {school.ja_description.split('\n')[0]}
    </p>
  )}

  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100 text-xs text-gray-400">
    <span>{school.department_count || '—'}学科</span>
    {school.student_count?.japanese != null && (
      <span>日本人 {school.student_count.japanese}名在籍</span>
    )}
  </div>
</a>

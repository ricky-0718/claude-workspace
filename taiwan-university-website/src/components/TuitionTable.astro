---
import type { TuitionItem } from '../data/loaders';

interface Props {
  items: TuitionItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-warm-200 text-left">
          <th class="py-2.5 pr-4 text-text-muted font-medium text-xs uppercase tracking-wider">学部</th>
          <th class="py-2.5 pr-4 text-text-muted font-medium text-xs uppercase tracking-wider">語学要件</th>
          <th class="py-2.5 text-text-muted font-medium text-right text-xs uppercase tracking-wider">学費/学期</th>
        </tr>
      </thead>
      <tbody>
        {items.map(item => (
          <tr class="border-b border-warm-100 last:border-b-0">
            <td class="py-2.5 pr-4 text-text">{item.faculty}</td>
            <td class="py-2.5 pr-4 text-text-muted text-xs">{item.requirement || '—'}</td>
            <td class="py-2.5 text-text text-right font-medium whitespace-nowrap">{item.amount}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

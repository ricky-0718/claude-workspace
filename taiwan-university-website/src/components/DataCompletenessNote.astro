---
interface Props {
  level: 'full' | 'enriched' | 'basic';
}

const { level } = Astro.props;

const messages: Record<string, { text: string; bg: string }> = {
  full: { text: '', bg: '' },
  enriched: {
    text: 'この大学の情報は一部のみ掲載しています。詳細はLINEでお問い合わせください。',
    bg: 'bg-accent-light border-accent/30',
  },
  basic: {
    text: 'この大学の日本語情報は限定的です。最新の出願情報はLINEでお問い合わせください。',
    bg: 'bg-warning-light border-warning/20',
  },
};

const msg = messages[level];
---

{msg.text && (
  <div class={`${msg.bg} border rounded-xl p-3.5 text-xs text-text-secondary leading-relaxed`}>
    {msg.text}
  </div>
)}

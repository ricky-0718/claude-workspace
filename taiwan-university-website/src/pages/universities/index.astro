---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import { schools, getRegions, getSchoolTypes } from '../../data/loaders';

const regions = getRegions();
const types = getSchoolTypes();
---

<PageLayout
  title="台湾の大学一覧（全129校） | 台湾大学データベース"
  description="台湾全129大学を地域・種別で検索。国立・私立の学費、寮、奨学金情報を日本語で掲載。"
  path="/universities/"
>
  <Breadcrumb items={[{ label: '大学一覧' }]} />

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-text">大学一覧</h1>
      <p class="text-sm text-text-muted mt-1">全{schools.length}校の台湾の大学を検索・比較</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-warm-200 rounded-2xl p-4 mb-6">
    <div class="flex flex-wrap gap-3" id="filters">
      <select
        id="filter-region"
        class="px-3.5 py-2 text-sm border border-warm-200 rounded-lg bg-warm-50 text-text-secondary focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-light transition-colors"
      >
        <option value="">全地域</option>
        {regions.map(r => <option value={r}>{r}</option>)}
      </select>

      <select
        id="filter-type"
        class="px-3.5 py-2 text-sm border border-warm-200 rounded-lg bg-warm-50 text-text-secondary focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-light transition-colors"
      >
        <option value="">全種別</option>
        {types.map(t => <option value={t}>{t}</option>)}
      </select>

      <label class="flex items-center gap-2 px-3.5 py-2 text-sm text-text-secondary border border-warm-200 rounded-lg bg-warm-50 cursor-pointer hover:border-primary transition-colors">
        <input type="checkbox" id="filter-dorm" class="accent-primary w-4 h-4 rounded" />
        寮あり
      </label>

      <label class="flex items-center gap-2 px-3.5 py-2 text-sm text-text-secondary border border-warm-200 rounded-lg bg-warm-50 cursor-pointer hover:border-primary transition-colors">
        <input type="checkbox" id="filter-scholarship" class="accent-primary w-4 h-4 rounded" />
        奨学金あり
      </label>

      <div class="flex-1"></div>

      <p id="result-count" class="self-center text-sm text-text-muted"></p>
    </div>
  </div>

  <!-- School Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="school-grid">
    {schools.map(school => (
      <SchoolCard school={school} />
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-16 text-text-muted">
    <svg class="w-12 h-12 mx-auto mb-3 text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <p class="text-lg font-medium">条件に一致する大学がありません</p>
    <p class="text-sm mt-1">フィルターを変更してお試しください</p>
  </div>
</PageLayout>

<script>
  const regionSelect = document.getElementById('filter-region') as HTMLSelectElement;
  const typeSelect = document.getElementById('filter-type') as HTMLSelectElement;
  const dormCheck = document.getElementById('filter-dorm') as HTMLInputElement;
  const scholarshipCheck = document.getElementById('filter-scholarship') as HTMLInputElement;
  const grid = document.getElementById('school-grid')!;
  const countEl = document.getElementById('result-count')!;
  const noResults = document.getElementById('no-results')!;
  const cards = Array.from(grid.children) as HTMLElement[];
  const total = cards.length;

  function applyFilters() {
    const region = regionSelect.value;
    const type = typeSelect.value;
    const dorm = dormCheck.checked;
    const scholarship = scholarshipCheck.checked;

    let visible = 0;
    for (const card of cards) {
      const show =
        (!region || card.dataset.region === region) &&
        (!type || card.dataset.type === type) &&
        (!dorm || card.dataset.dorm === 'true') &&
        (!scholarship || card.dataset.scholarship === 'true');

      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    countEl.textContent = visible === total ? '' : `${visible}校 / ${total}校`;
    noResults.classList.toggle('hidden', visible > 0);
  }

  regionSelect.addEventListener('change', applyFilters);
  typeSelect.addEventListener('change', applyFilters);
  dormCheck.addEventListener('change', applyFilters);
  scholarshipCheck.addEventListener('change', applyFilters);
</script>

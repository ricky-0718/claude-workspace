---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import { schools } from '../../data/loaders';

import rankingsData from '../../data/rankings-2026.json';

const rankings = rankingsData.rankings || [];

// Build school slug lookup (handle name variants)
const schoolByName = new Map<string, string>();
for (const s of schools) {
  const slug = s.resolvedSlug || s.slug;
  schoolByName.set(s.name.cht, slug);
  const stripped = s.name.cht.replace(/^天主教/, '').replace(/^學校財團法人/, '');
  if (stripped !== s.name.cht) schoolByName.set(stripped, slug);
}

function getSlug(nameCht: string): string | null {
  return schoolByName.get(nameCht) || schoolByName.get('天主教' + nameCht) || null;
}

function formatRank(rank: any): string {
  if (rank == null) return '—';
  return String(rank);
}

function sortKey(rank: any): number {
  if (rank == null) return 99999;
  if (typeof rank === 'number') return rank;
  const match = String(rank).match(/^(\d+)/);
  return match ? parseInt(match[1]) : 99998;
}

const byQsWorld = [...rankings].filter(r => r.qs_world != null).sort((a, b) => sortKey(a.qs_world) - sortKey(b.qs_world));
const byQsAsia = [...rankings].filter(r => r.qs_asia != null).sort((a, b) => sortKey(a.qs_asia) - sortKey(b.qs_asia));
const byThe = [...rankings].filter(r => r.the_world != null).sort((a, b) => sortKey(a.the_world) - sortKey(b.the_world));
const byCheers = [...rankings].filter(r => r.cheers != null || r.yuanjian != null).sort((a, b) => sortKey(a.cheers) - sortKey(b.cheers));
---

<PageLayout
  title="台湾の大学ランキング 2026年版 | 台湾大学データベース"
  description="QS・THE・Cheers・遠見の最新ランキングで台湾の大学を比較。世界順位・アジア順位・企業人気ランキングを一覧。"
  path="/rankings/"
>
  <Breadcrumb items={[{ label: 'ランキング' }]} />

  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-text">台湾の大学ランキング</h1>
    <p class="text-sm text-text-muted mt-2 max-w-2xl">
      4つの主要ランキングを掲載。{rankings.length}校の台湾大学を国際的な視点で比較できます。
    </p>
    <div class="mt-4">
      <a href="/rankings/japan-comparison/" class="inline-flex items-center gap-2 text-sm text-primary font-medium hover:underline">
        <Icon name="chartBar" size={16} />
        日本の大学と比較する →
      </a>
    </div>
  </div>

  <!-- Tab navigation — 4 tabs -->
  <div class="flex gap-1 border-b border-warm-200 mb-6 overflow-x-auto" id="ranking-tabs">
    <button class="tab-btn active px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary whitespace-nowrap" data-tab="qs-world">QS世界</button>
    <button class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap" data-tab="qs-asia">QSアジア</button>
    <button class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap" data-tab="the-world">THE世界</button>
    <button class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap" data-tab="employer">企業人気</button>
  </div>

  <!-- ====== QS World ====== -->
  <div class="tab-content" id="tab-qs-world">
    <div class="bg-white border border-warm-200 rounded-2xl overflow-hidden">
      <div class="px-5 py-3 bg-warm-50 border-b border-warm-200">
        <h2 class="text-sm font-bold text-text">QS World University Rankings 2026</h2>
        <p class="text-xs text-text-muted mt-0.5">Quacquarelli Symonds社による世界大学ランキング（{byQsWorld.length}校掲載）</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-warm-200 text-left">
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider w-20">世界順位</th>
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider">大学名</th>
            </tr>
          </thead>
          <tbody>
            {byQsWorld.map((r, i) => {
              const slug = getSlug(r.name_cht);
              return (
                <tr class={`border-b border-warm-100 last:border-b-0 ${i < 3 ? 'bg-accent-light/30' : ''}`}>
                  <td class="px-5 py-3 font-bold text-primary">{formatRank(r.qs_world)}</td>
                  <td class="px-5 py-3">
                    {slug ? (
                      <a href={`/universities/${slug}/`} class="text-text hover:text-primary transition-colors font-medium">
                        {r.name_cht}
                      </a>
                    ) : (
                      <span class="text-text">{r.name_cht}</span>
                    )}
                    <div class="text-xs text-text-muted mt-0.5">{r.name_en}</div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ====== QS Asia ====== -->
  <div class="tab-content hidden" id="tab-qs-asia">
    <div class="bg-white border border-warm-200 rounded-2xl overflow-hidden">
      <div class="px-5 py-3 bg-warm-50 border-b border-warm-200">
        <h2 class="text-sm font-bold text-text">QS Asia University Rankings 2026</h2>
        <p class="text-xs text-text-muted mt-0.5">アジア地域に特化したQSランキング（{byQsAsia.length}校掲載）</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-warm-200 text-left">
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider w-20">アジア順位</th>
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider">大学名</th>
            </tr>
          </thead>
          <tbody>
            {byQsAsia.map((r, i) => {
              const slug = getSlug(r.name_cht);
              return (
                <tr class={`border-b border-warm-100 last:border-b-0 ${i < 3 ? 'bg-accent-light/30' : ''}`}>
                  <td class="px-5 py-3 font-bold text-primary">{formatRank(r.qs_asia)}</td>
                  <td class="px-5 py-3">
                    {slug ? (
                      <a href={`/universities/${slug}/`} class="text-text hover:text-primary transition-colors font-medium">
                        {r.name_cht}
                      </a>
                    ) : (
                      <span class="text-text">{r.name_cht}</span>
                    )}
                    <div class="text-xs text-text-muted mt-0.5">{r.name_en}</div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ====== THE World ====== -->
  <div class="tab-content hidden" id="tab-the-world">
    <div class="bg-white border border-warm-200 rounded-2xl overflow-hidden">
      <div class="px-5 py-3 bg-warm-50 border-b border-warm-200">
        <h2 class="text-sm font-bold text-text">Times Higher Education World University Rankings 2026</h2>
        <p class="text-xs text-text-muted mt-0.5">英Times Higher Education社による世界大学ランキング（{byThe.length}校掲載）</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-warm-200 text-left">
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider w-20">世界順位</th>
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider">大学名</th>
            </tr>
          </thead>
          <tbody>
            {byThe.map((r, i) => {
              const slug = getSlug(r.name_cht);
              return (
                <tr class={`border-b border-warm-100 last:border-b-0 ${i < 3 ? 'bg-accent-light/30' : ''}`}>
                  <td class="px-5 py-3 font-bold text-primary">{formatRank(r.the_world)}</td>
                  <td class="px-5 py-3">
                    {slug ? (
                      <a href={`/universities/${slug}/`} class="text-text hover:text-primary transition-colors font-medium">
                        {r.name_cht}
                      </a>
                    ) : (
                      <span class="text-text">{r.name_cht}</span>
                    )}
                    <div class="text-xs text-text-muted mt-0.5">{r.name_en}</div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ====== Employer (Cheers + 遠見) ====== -->
  <div class="tab-content hidden" id="tab-employer">
    <div class="bg-white border border-warm-200 rounded-2xl overflow-hidden">
      <div class="px-5 py-3 bg-warm-50 border-b border-warm-200">
        <h2 class="text-sm font-bold text-text">企業が最も採用したい大学 2026</h2>
        <p class="text-xs text-text-muted mt-0.5">Cheers天下雑誌・遠見雑誌による台湾企業アンケート（{byCheers.length}校掲載）</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-warm-200 text-left">
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider w-20">Cheers</th>
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider">大学名</th>
              <th class="px-5 py-3 text-xs font-medium text-text-muted uppercase tracking-wider text-right w-20">遠見</th>
            </tr>
          </thead>
          <tbody>
            {byCheers.map((r, i) => {
              const slug = getSlug(r.name_cht);
              return (
                <tr class={`border-b border-warm-100 last:border-b-0 ${i < 3 ? 'bg-accent-light/30' : ''}`}>
                  <td class="px-5 py-3 font-bold text-primary">{formatRank(r.cheers)}</td>
                  <td class="px-5 py-3">
                    {slug ? (
                      <a href={`/universities/${slug}/`} class="text-text hover:text-primary transition-colors font-medium">
                        {r.name_cht}
                      </a>
                    ) : (
                      <span class="text-text">{r.name_cht}</span>
                    )}
                    <div class="text-xs text-text-muted mt-0.5">{r.name_en}</div>
                  </td>
                  <td class="px-5 py-3 text-right text-text-muted font-medium">{formatRank(r.yuanjian)}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Data note -->
  <p class="text-xs text-text-muted mt-6 text-center">
    データ出典: QS TopUniversities / Times Higher Education / Cheers天下雑誌 / 遠見雑誌（2026年版）
  </p>
</PageLayout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;

      tabs.forEach(t => {
        t.classList.remove('active', 'border-primary', 'text-primary');
        t.classList.add('border-transparent', 'text-text-muted');
      });
      tab.classList.add('active', 'border-primary', 'text-primary');
      tab.classList.remove('border-transparent', 'text-text-muted');

      contents.forEach(c => {
        c.classList.toggle('hidden', c.id !== `tab-${target}`);
      });
    });
  });
</script>

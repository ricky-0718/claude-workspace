---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import InlineCTA from '../../components/InlineCTA.astro';
import { getQsWorldRows, getQsAsiaRows, getTheWorldRows, getCheersRows } from '../../utils/rankingHelpers';

const qsWorldCount = getQsWorldRows().length;
const qsAsiaCount = getQsAsiaRows().length;
const theCount = getTheWorldRows().length;
const cheersCount = getCheersRows().length;

const rankingCards = [
  {
    href: '/rankings/qs-world/',
    title: 'QS世界大学ランキング',
    subtitle: 'QS World University Rankings 2026',
    count: qsWorldCount,
    description: '世界的に最も参照される大学ランキング。学術評価・雇用主評価・論文引用数・国際性など6つの指標で評価。',
    useCase: '台湾の大学の国際的なポジションを知りたい方に',
  },
  {
    href: '/rankings/qs-asia/',
    title: 'QSアジア大学ランキング',
    subtitle: 'QS Asia University Rankings 2026',
    count: qsAsiaCount,
    description: 'QS社がアジア地域に特化して発表。日本・韓国・シンガポール等の大学と比較しやすい指標。',
    useCase: 'アジア圏での大学選びを検討している方に',
  },
  {
    href: '/rankings/the/',
    title: 'THE世界大学ランキング',
    subtitle: 'Times Higher Education 2026',
    count: theCount,
    description: '教育・研究・論文引用・国際性・産業連携の5項目13指標で評価。研究志向の大学が高評価。',
    useCase: '研究力の高い大学を選びたい方に',
  },
  {
    href: '/rankings/cheers/',
    title: '企業採用人気ランキング',
    subtitle: 'Cheers天下雑誌・遠見雑誌 2026',
    count: cheersCount,
    description: '台湾企業の人事担当者アンケートに基づく「採用したい大学」ランキング。',
    useCase: '台湾現地で就職を目指す方に',
  },
];
---

<PageLayout
  title="台湾の大学ランキング 2026年版（QS・THE・Cheers）| 台湾大学データベース"
  description="台湾の大学を4つの主要ランキング（QS世界・QSアジア・THE世界・Cheers企業採用）で比較。国際評価・研究力・就職実績の観点で最適な大学を見つけられます。"
  path="/rankings/"
  pageType="rankings"
>
  <Breadcrumb items={[{ label: 'ランキング' }]} />

  <div class="mb-10">
    <h1 class="text-2xl sm:text-3xl font-bold text-text">台湾の大学ランキング</h1>
    <p class="text-sm text-text-muted mt-2 max-w-2xl">
      台湾の大学を4つの主要ランキングで比較できます。それぞれ評価基準が異なるため、「国際性を重視するか」「研究力を重視するか」「就職実績を重視するか」で参照すべきランキングが変わります。
    </p>
  </div>

  <!-- Ranking cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
    {rankingCards.map(card => (
      <a
        href={card.href}
        class="group bg-white border border-warm-200 rounded-2xl p-6 hover:border-primary hover:shadow-md transition-all"
      >
        <div class="flex items-start justify-between mb-3">
          <div>
            <h2 class="text-lg font-bold text-text group-hover:text-primary transition-colors">{card.title}</h2>
            <p class="text-xs text-text-muted mt-0.5">{card.subtitle}</p>
          </div>
          <span class="text-xs font-bold bg-warm-50 text-text-muted px-2.5 py-1 rounded-full whitespace-nowrap">
            {card.count}校
          </span>
        </div>
        <p class="text-sm text-text-muted leading-relaxed mb-3">{card.description}</p>
        <div class="flex items-center justify-between text-xs">
          <span class="text-text-muted">{card.useCase}</span>
          <span class="text-primary font-medium group-hover:underline inline-flex items-center gap-1">
            一覧を見る
            <Icon name="chevronRight" size={14} />
          </span>
        </div>
      </a>
    ))}
  </div>

  <!-- Japan comparison link -->
  <div class="bg-gradient-to-r from-accent-light/40 to-warm-50 border border-warm-200 rounded-2xl p-6 mb-10">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white flex items-center justify-center text-primary">
        <Icon name="chartBar" size={24} />
      </div>
      <div class="flex-1">
        <h2 class="text-base font-bold text-text mb-1">日本の大学と比較する</h2>
        <p class="text-sm text-text-muted mb-3">
          「台湾の国立大学は日本のどのレベル？」を可視化。QS世界ランキングで日本と台湾の大学を横並びで比較できます。
        </p>
        <a href="/rankings/japan-comparison/" class="inline-flex items-center gap-1.5 text-sm text-primary font-medium hover:underline">
          日本 vs 台湾の比較を見る
          <Icon name="chevronRight" size={14} />
        </a>
      </div>
    </div>
  </div>

  <!-- How to use rankings -->
  <div class="bg-white border border-warm-200 rounded-2xl p-6 mb-10">
    <h2 class="text-base font-bold text-text mb-3">ランキングの使い分け方</h2>
    <ul class="space-y-2.5 text-sm text-text-muted">
      <li class="flex gap-2"><span class="text-primary font-bold">・</span><span><strong class="text-text">国際的な知名度を重視する場合：</strong>QS世界ランキングが最も参照される</span></li>
      <li class="flex gap-2"><span class="text-primary font-bold">・</span><span><strong class="text-text">アジア圏での進路を考える場合：</strong>QSアジアで他アジア諸国と比較</span></li>
      <li class="flex gap-2"><span class="text-primary font-bold">・</span><span><strong class="text-text">研究者・大学院進学を視野に：</strong>THE世界ランキングが研究実績に強い</span></li>
      <li class="flex gap-2"><span class="text-primary font-bold">・</span><span><strong class="text-text">台湾現地で就職を目指す：</strong>Cheers・遠見の企業採用ランキング</span></li>
    </ul>
  </div>

  <InlineCTA
    heading="ランキングだけで大学は決められない"
    body="出願要件・語学レベル・日本人受入実績・学費の全てを考慮した進路選びを、無料ガイドブックで解説。"
    pageType="rankings"
  />
</PageLayout>

---
import PageLayout from '../layouts/PageLayout.astro';
import GroupCard from '../components/GroupCard.astro';
import StatCard from '../components/StatCard.astro';
import { schools, departments, groups } from '../data/loaders';
---

<PageLayout
  title="台湾大学データベース | 台湾留学101"
  description="台湾全129大学・2,371学科を日本語で検索。学費・奨学金・寮情報を比較できます。"
  path="/"
>
  <!-- Hero -->
  <section class="text-center py-8 sm:py-12">
    <h1 class="text-2xl sm:text-4xl font-black text-gray-900 leading-tight">
      台湾の大学を<span class="text-primary">日本語</span>で探せる
    </h1>
    <p class="mt-3 text-gray-500 text-sm sm:text-base max-w-lg mx-auto">
      全{schools.length}大学・{departments.length.toLocaleString()}学科の出願情報を網羅。
      学群・地域・条件で簡単に検索できます。
    </p>

    <!-- Search -->
    <div class="max-w-md mx-auto mt-6" id="search"></div>

    <!-- Quick links -->
    <div class="flex justify-center gap-3 mt-6">
      <a
        href="/universities/"
        class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-primary-dark transition-colors"
      >
        大学一覧を見る
      </a>
      <a
        href="/groups/"
        class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-5 py-2.5 rounded-xl text-sm font-bold hover:border-primary hover:text-primary transition-colors"
      >
        学群から探す
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-3 gap-4 py-6 border-y border-gray-100">
    <StatCard value={schools.length} label="大学" />
    <StatCard value={departments.length.toLocaleString()} label="学科" />
    <StatCard value={groups.length} label="学群" />
  </section>

  <!-- Groups Grid -->
  <section class="py-8">
    <h2 class="text-lg font-bold text-gray-800 mb-4">学群から探す</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {groups.map(group => (
        <GroupCard group={group} />
      ))}
    </div>
  </section>

  <!-- Popular Universities -->
  <section class="py-8">
    <h2 class="text-lg font-bold text-gray-800 mb-4">人気の大学</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {schools.filter(s => s.data_completeness === 'full').slice(0, 6).map(school => (
        <a
          href={`/universities/${school.resolvedSlug}/`}
          class="flex items-center gap-3 p-4 bg-white border border-gray-200 rounded-xl hover:border-primary hover:shadow-sm transition-all"
        >
          <div class="w-10 h-10 rounded-lg bg-primary-light flex items-center justify-center text-primary font-bold text-sm shrink-0">
            {school.name.ja.charAt(0)}
          </div>
          <div class="min-w-0">
            <div class="font-bold text-sm text-gray-800 truncate">{school.name.ja}</div>
            <div class="text-xs text-gray-400 mt-0.5">{school.region} · {school.department_count || '—'}学科</div>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-4">
      <a href="/universities/" class="text-sm text-primary hover:underline">
        全{schools.length}校を見る →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary-light rounded-2xl p-6 sm:p-8 text-center my-8">
    <h2 class="text-lg font-bold text-gray-800">台湾留学のご相談はLINEで</h2>
    <p class="text-sm text-gray-500 mt-2 max-w-md mx-auto">
      志望校選び・出願手続き・奨学金のことなど、お気軽にご相談ください。
    </p>
    <a
      href="https://lin.ee/placeholder"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-[#06c755] text-white px-6 py-3 rounded-xl text-sm font-bold mt-4 hover:bg-[#05b34c] transition-colors"
    >
      LINEで無料相談する
    </a>
  </section>
</PageLayout>

<script is:inline>
  window.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('search');
    if (!el) return;
    var s = document.createElement('script');
    s.src = '/pagefind/pagefind-ui.js';
    s.onload = function() {
      new PagefindUI({
        element: '#search',
        showImages: false,
        showSubResults: true,
        translations: {
          placeholder: '大学名・学科名で検索...',
          zero_results: '「[SEARCH_TERM]」に一致する結果がありません',
        },
      });
    };
    document.head.appendChild(s);
  });
</script>

<style is:global>
  .pagefind-ui__search-input {
    border-radius: 0.75rem !important;
    border-color: #e5e7eb !important;
    font-size: 0.875rem !important;
    padding: 0.75rem 1rem !important;
  }
  .pagefind-ui__search-input:focus {
    border-color: #4a6fa5 !important;
    box-shadow: 0 0 0 2px #e8eef6 !important;
  }
  .pagefind-ui__result-link {
    color: #4a6fa5 !important;
    font-weight: 600 !important;
  }
</style>

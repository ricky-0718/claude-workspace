---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import GroupCard from '../../components/GroupCard.astro';
import { groups } from '../../data/loaders';
---

<PageLayout
  title="学群一覧（全18学群） | 台湾大学データベース"
  description="台湾の大学を18の学群（分野）から探せます。情報学、工学、医療、経営など2,371学科を網羅。"
  path="/groups/"
>
  <Breadcrumb items={[{ label: '学群一覧' }]} />

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-text">学群一覧</h1>
    <p class="text-sm text-text-muted mt-1">全{groups.length}学群から興味のある分野を探す</p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3 sm:gap-4">
    {groups.map(group => (
      <GroupCard group={group} />
    ))}
  </div>
</PageLayout>

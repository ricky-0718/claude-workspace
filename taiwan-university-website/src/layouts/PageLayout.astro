---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LineCTA from '../components/LineCTA.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  ogType?: string;
  pageType?: string;
  schoolSlug?: string;
}

const { title, description, path, ogType, pageType = 'top', schoolSlug } = Astro.props;
---

<BaseLayout title={title} description={description} path={path} ogType={ogType}>
  <slot name="head" slot="head" />
  <Header />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-8 pb-24 sm:pb-8">
    <slot />
  </main>
  <Footer />
  <LineCTA pageType={pageType} schoolSlug={schoolSlug} />
</BaseLayout>
